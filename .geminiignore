# Secrets and local server notes
.env
.env.*
!.env.example
!backend/.env.example
/.server-credentials
/server-info.md

# Large reference dumps; open a specific file only for provider API work
/docs/site/

# OS/editor
.DS_Store
.idea/
.vscode/
